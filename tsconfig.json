{
	"compilerOptions": {
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"target": "es2023",
		"module": "node20",
		"moduleResolution": "nodenext",
		"allowJs": true,
		"noImplicitAny": false,
		"outDir": "../package/lib",
		"declaration": true,
		"declarationMap": true,
		"removeComments": true
	},
	"exclude": ["./dist", "copyPackageFiles.cjs"],
	"include": ["./src/*.ts", "./sec/*.d.ts"]
}
