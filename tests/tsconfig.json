{
	"compilerOptions": {
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"target": "es2023",
		"module": "es2020",
		"allowJs": true,
		"noImplicitAny": false,
		"sourceMap": true,
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"removeComments": true
	},
	"exclude": ["../dist"],
	"include": ["./**/*.ts", "./**/*.d.ts"]
}
